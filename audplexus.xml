<?xml version="1.0"?>
<Container version="2">
    <Name>Audplexus</Name>
    <Repository>ghcr.io/mstrhakr/audplexus</Repository>
    <Registry>https://github.com/orgs/mstrhakr/packages/container/package/audplexus</Registry>
    <Network>bridge</Network>
    <Privileged>false</Privileged>
    <Beta>True</Beta>
    <Support>https://github.com/mstrhakr/audplexus/issues/</Support>
    <Shell>sh</Shell>
    <GitHub>https://github.com/mstrhakr/audplexus#configuration</GitHub>
    <ReadMe>https://github.com/mstrhakr/audplexus#readme</ReadMe>
    <Branch>
        <Tag>latest</Tag>
        <TagDescription>Stable releases</TagDescription>
    </Branch>
    <Branch>
        <Tag>master</Tag>
        <TagDescription>Latest commits from the master branch</TagDescription>
        <ReadMe>https://github.com/mstrhakr/audplexus/tree/master#readme</ReadMe>
        <GitHub>https://github.com/mstrhakr/audplexus/tree/master#configuration</GitHub>
    </Branch>
    <Category>Downloaders:MediaApp:Network:Web</Category>
    <Icon>https://raw.githubusercontent.com/mstrhakr/audplexus/master/logo.png</Icon>
    <Overview>Download Audible titles, remove DRM with FFmpeg, enrich metadata from Audnexus, and organize audiobooks for Plex from a web UI.</Overview>
    <WebUI>http://[IP]:[PORT:8080]</WebUI>
    <TemplateURL>https://raw.githubusercontent.com/mstrhakr/plugin-repository/main/audplexus.xml</TemplateURL>
    <Config Name="WebUI" Target="8080" Default="8080" Mode="tcp" Description="HTTP port for the WebUI." Type="Port" Display="always" Required="true" Mask="false"/>
    <Config Name="Config" Target="/config" Default="/mnt/user/appdata/audplexus/config" Mode="rw" Description="Persistent config, auth, and database files." Type="Path" Display="always" Required="true" Mask="false"/>
    <Config Name="Audiobooks" Target="/audiobooks" Default="/mnt/user/media/audiobooks" Mode="rw" Description="Final organized audiobook library path (Plex root)." Type="Path" Display="always" Required="true" Mask="false"/>
    <Config Name="Downloads" Target="/downloads" Default="/mnt/user/appdata/audplexus/downloads" Mode="rw" Description="Temporary download and processing workspace." Type="Path" Display="always" Required="true" Mask="false"/>
    <Config Name="PUID" Target="PUID" Default="99" Description="Container Variable: PUID" Type="Variable" Display="advanced" Required="true" Mask="false"/>
    <Config Name="PGID" Target="PGID" Default="100" Description="Container Variable: PGID" Type="Variable" Display="advanced" Required="true" Mask="false"/>
    <Config Name="TAKE_OWNERSHIP" Target="TAKE_OWNERSHIP" Default="false" Description="Container Variable: TAKE_OWNERSHIP" Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="DATABASE_TYPE" Target="DATABASE_TYPE" Default="sqlite" Description="Container Variable: DATABASE_TYPE (sqlite or postgres)." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="PLEX_URL" Target="PLEX_URL" Default="" Description="Container Variable: PLEX_URL (optional Plex server URL)." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="PLEX_TOKEN" Target="PLEX_TOKEN" Default="" Description="Container Variable: PLEX_TOKEN (optional Plex token)." Type="Variable" Display="advanced" Required="false" Mask="true"/>
    <Config Name="PLEX_SECTION_ID" Target="PLEX_SECTION_ID" Default="" Description="Container Variable: PLEX_SECTION_ID (optional Plex library section ID)." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="SYNC_SCHEDULE" Target="SYNC_SCHEDULE" Default="0 */6 * * *" Description="Container Variable: SYNC_SCHEDULE (cron expression)." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="SYNC_MODE" Target="SYNC_MODE" Default="full" Description="Container Variable: SYNC_MODE (quick or full)." Type="Variable" Display="advanced" Required="false" Mask="false"/>
</Container>